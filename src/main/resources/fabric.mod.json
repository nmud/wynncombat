{
	"schemaVersion": 1,
	"id": "wynncombat",
	"version": "${version}",
	"name": "WynnCombat",
	"description": "WynnCombat - a combat mod for Minecraft.",
	"authors": [
		"smirk"
	],
	"contact": {
		"homepage": "https://github.com/nmud/WynnCombat",
		"sources": "https://github.com/nmud/WynnCombat"
	},
	"license": "CC0-1.0",
	"icon": "assets/wynncombat/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"io.github.nmud.wynncombat.WynnCombat"
		],
		"client": [
			"io.github.nmud.wynncombat.client.WynnCombatClient"
		]
	},
	"mixins": [
		"wynncombat.mixins.json",
		{
			"config": "wynncombat.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}
